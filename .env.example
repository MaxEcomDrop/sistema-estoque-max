# ====== BLING OAuth ======
# Obtenha estes valores em: https://www.bling.com.br/b/configuracoes/integracoes/chaves
BLING_CLIENT_ID=seu_client_id_aqui
BLING_CLIENT_SECRET=sua_client_secret_aqui

# IMPORTANTE: Certifique-se de que a URL abaixo está configurada no Bling
# Desenvolvimento: http://localhost:3000/api/auth/callback
# Produção: https://seu-dominio.vercel.app/api/auth/callback
BLING_REDIRECT_URI=https://sistema-estoque-max.vercel.app/api/auth/callback

# ====== Login do painel (OBRIGATÓRIO) ======
# Sem estas duas variáveis, o login por email/senha NUNCA funciona.
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=defina_uma_senha_forte

# ====== Server ======
PORT=3000
NODE_ENV=production

# ====== JWT Secret ======
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_segura_com_32_caracteres_aleatorios

# ====== Firebase (opcional — login com Google, push notifications e persistência do token do Mercado Livre) ======
# JSON completo da service account, em uma única linha
FIREBASE_SERVICE_ACCOUNT=

# ====== Mercado Livre OAuth (opcional — aba Mercado Livre, dados 100% separados do Bling) ======
# Obtenha estes valores em: https://developers.mercadolivre.com.br/
# IMPORTANTE: requer FIREBASE_SERVICE_ACCOUNT configurado (o refresh_token é persistido no Firestore)
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://seu-dominio/api/ml/callback

# ====== Vercel (Opcional) ======
# Estas variáveis são definidas automaticamente pelo Vercel
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=seu-dominio.vercel.app
