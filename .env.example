# ====== BLING OAuth ======
# Obtenha estes valores em: https://www.bling.com.br/b/configuracoes/integracoes/chaves
BLING_CLIENT_ID=seu_client_id_aqui
BLING_CLIENT_SECRET=sua_client_secret_aqui

# IMPORTANTE: Certifique-se de que a URL abaixo está configurada no Bling
# Desenvolvimento: http://localhost:3000/api/auth/callback
# Produção: https://seu-dominio.vercel.app/api/auth/callback
BLING_REDIRECT_URI=https://sistema-estoque-max.vercel.app/api/auth/callback

# ====== Server ======
PORT=3000
NODE_ENV=production

# ====== JWT Secret ======
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_segura_com_32_caracteres_aleatorios

# ====== Vercel (Opcional) ======
# Estas variáveis são definidas automaticamente pelo Vercel
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=seu-dominio.vercel.app
