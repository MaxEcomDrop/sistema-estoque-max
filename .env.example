# ====== Bling OAuth ======
# Obtenha estes valores em: https://www.bling.com.br/b/configuracoes/integracoes/chaves
BLING_CLIENT_ID=seu_client_id_aqui
BLING_CLIENT_SECRET=sua_client_secret_aqui

# IMPORTANTE: esta URL deve estar cadastrada no app do Bling e apontar
# para o domínio real onde o sistema está publicado (Vercel, Render, etc.)
# Desenvolvimento: http://localhost:3000/api/auth/callback
# Produção:        https://seu-dominio/api/auth/callback
BLING_REDIRECT_URI=https://seu-dominio/api/auth/callback

# ====== Mercado Livre OAuth (opcional) ======
# Obtenha estes valores em: https://developers.mercadolivre.com.br/
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# Deve estar cadastrada no app do Mercado Livre, apontando para o domínio real
ML_REDIRECT_URI=https://seu-dominio/api/ml/callback

# ====== Login do painel ======
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=defina_uma_senha_forte

# ====== JWT Secret ======
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=gere_uma_chave_segura_com_32_caracteres_aleatorios

# ====== Firebase (opcional — push notifications) ======
# JSON completo da service account, em uma única linha
FIREBASE_SERVICE_ACCOUNT=

# ====== Cron (opcional) ======
# Protege o endpoint /api/cron/push; se vazio, o endpoint fica liberado
CRON_SECRET=

# ====== Server ======
PORT=3000
NODE_ENV=production
