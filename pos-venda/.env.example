# ── Bling (OAuth2 — decisão do projeto: os tokens vivem no Firestore,
#    mantidos pelo sistema principal; aqui só precisamos das credenciais
#    do app para renovar quando o access token expirar) ──
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
# Chave de assinatura configurada ao cadastrar o webhook no Bling (HMAC-SHA256)
BLING_WEBHOOK_SECRET=

# ── Mercado Livre ──
# ID do aplicativo (valida a origem das notificações)
ML_APP_ID=

# ── Firebase ──
# JSON da service account, serializado em uma única linha
FIREBASE_SERVICE_ACCOUNT=
# Somente se o banco Firestore tiver ID diferente de (default)
FIRESTORE_DB_ID=

# ── Cache ──
CACHE_TTL_HOURS=24

NODE_ENV=production

# ── Diagnóstico ──
# Protege /api/status, /api/recent e a página inicial (?key=... ou header
# x-admin-key). Sem ela, o diagnóstico fica aberto — defina em produção.
ADMIN_KEY=
